# AutoNetLab Frontend Environment Settings

# true  = use local mock JSON data
# false = call real backend API
VITE_USE_MOCK_API=true

# Local development with FastAPI running directly on port 8000:
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Production deployment behind Nginx reverse proxy:
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=/api/v1
